# =============================================================================
# Self-Healing RAG Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env inside the backend folder and fill in your values:
#   cd backend && cp .example.env .env
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB Atlas
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=self_healing_rag

# -----------------------------------------------------------------------------
# LLM Provider (chat + LangGraph nodes)
# Supported: groq | openai | openrouter
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key
CHAT_MODEL=llama-3.3-70b-versatile
CHAT_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# Embeddings Provider (document upload + vector retrieval)
# Supported: openrouter | openai | azure | gemini | voyage
# Note: Groq does NOT provide embeddings — use OpenRouter or OpenAI.
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# OpenAI (optional — use when EMBEDDING_PROVIDER=openai or LLM_PROVIDER=openai)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Azure OpenAI (optional — use when EMBEDDING_PROVIDER=azure)
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=

# -----------------------------------------------------------------------------
# Gemini / Voyage (optional — use when EMBEDDING_PROVIDER=gemini or voyage)
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=
VOYAGE_API_KEY=

# -----------------------------------------------------------------------------
# RAG Settings
# -----------------------------------------------------------------------------
MAX_RETRIES=3
TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_UPLOAD_MB=20
VECTOR_INDEX_NAME=vector_index

# -----------------------------------------------------------------------------
# App Settings
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_KEY=admin-secret
